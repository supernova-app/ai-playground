# Basic

VITE_BASE_URL = "http://localhost:5173"

# DB

DATABASE_URL = "postgresql://postgres:postgres@localhost:5432/defaultdb"

# AI Gateway (Vercel)
# All AI providers are accessed through the Vercel AI Gateway — no per-provider keys needed
# On Vercel deployments, VERCEL_OIDC_TOKEN is used as a fallback if AI_GATEWAY_API_KEY is not set
AI_GATEWAY_API_KEY = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Auth

## Better Auth

BETTER_AUTH_SECRET = "something-very-secret"
BETTER_AUTH_URL = "http://localhost:5173" # Base URL of your app

# The redirect URI will be BASE_URL/api/auth/callback/{provider}

### Google

BETTER_AUTH_GOOGLE_CLIENT_ID = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
BETTER_AUTH_GOOGLE_CLIENT_SECRET = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
